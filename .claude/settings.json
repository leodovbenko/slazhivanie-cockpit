{
  "defaultMode": "acceptEdits",
  "permissions": {
    "allow": [
      "Bash(*)",
      "WebFetch",
      "WebSearch",
      "mcp__publora__list_posts",
      "mcp__publora__list_connections",
      "mcp__publora__get_post",
      "mcp__publora__get_upload_url",
      "mcp__claude_ai_Google_Drive__search_files",
      "mcp__claude_ai_Google_Drive__get_file_metadata",
      "mcp__claude_ai_Buildin_Dxbx__API-search",
      "mcp__claude_ai_Buildin_Dxbx__API-semanticSearch"
    ],
    "ask": [
      "Bash(rm -rf*)",
      "Bash(rm -fr*)",
      "Bash(rm -r *)",
      "Bash(sudo rm*)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(dd *)",
      "Bash(mkfs*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/guardrail.py\""
          },
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/verify-gate.py\""
          },
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/declaration-gate.py\""
          }
        ]
      }
    ]
  }
}
